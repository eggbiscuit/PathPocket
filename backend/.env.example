# Copy to .env and fill in. NEVER commit the real .env.

# Database — dev uses local SQLite; prod uses Postgres, e.g.
#   postgresql+asyncpg://user:pass@localhost:5432/pathpocket
DATABASE_URL=sqlite+aiosqlite:///./pathpocket.db

# JWT — generate a long random secret, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# First admin — seeded/promoted on startup. Login with these to approve users.
ADMIN_EMAIL=admin@pathpocket.dev
ADMIN_PASSWORD=change-me-admin-password

# Public base URL of THIS backend, used to build the email-verification link.
BACKEND_BASE_URL=http://localhost:8000

# CORS — comma-separated list of allowed origins (the Flutter web app).
# Include the real site origin in prod, e.g.
#   https://smartpath-evidence.site.ngrok.app
CORS_ORIGINS=http://localhost:8080,http://localhost:3000
# Optional regex for dynamic origins (e.g. rotating ngrok subdomains). Leave
# empty to disable. Example: ^https://.*\.ngrok\.app$
CORS_ORIGIN_REGEX=

# SMTP — if unset, emails are printed to the console (dev mode).
# Recommended: Resend (https://resend.com) — free 3000 emails/month.
#   1. Sign up, add domain smartpath-evidence.site, give DNS records to DNS admin.
#   2. Once domain verified, create an API Key (starts with re_).
#   3. Fill in below. SMTP_USER is always the literal string "resend".
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_your_api_key_here
SMTP_FROM=PathPocket <smart@smartpath-evidence.site>
